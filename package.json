{
  "name": "waypause",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev:web": "pnpm --filter @waypause/web dev",
    "dev:api": "pnpm --filter @waypause/api start:dev",
    "dev:mobile": "pnpm --filter @waypause/mobile start",
    "build:web": "pnpm --filter @waypause/web build",
    "build:api": "pnpm --filter @waypause/api build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "esbuild",
      "sharp"
    ]
  }
}
